# --- GitHub API (server-only, never NEXT_PUBLIC_) ---
# Used at runtime by Next.js ISR — must be set in Coolify Environment Variables
# (Available at Runtime), not only as a build-time secret.
#
# Classic PAT scopes: repo (private + collaborator repos), read:user
# Fine-grained: access to your repos + Metadata read; add org repos if needed
#
# Create: https://github.com/settings/tokens
GITHUB_TOKEN=

# Database connection URL (supports Postgres/Neon)
DATABSE_URL=

# --- Better Auth Configurations ---
# Secure random string used to encrypt tokens (run openssl rand -base64 32 to generate)
BETTER_AUTH_SECRET=
# The base URL of your auth server (e.g., http://localhost:3000 in dev or https://www.shorno.me in prod)
BETTER_AUTH_URL=
# The base URL of your client app (e.g., http://localhost:3000 in dev or https://www.shorno.me in prod)
NEXT_PUBLIC_APP_URL=
